        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>d365Environment</ont:fromEntityId>
        <ont:toEntityId>company</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- DataClassification → SharePointSite (applied to) -->
