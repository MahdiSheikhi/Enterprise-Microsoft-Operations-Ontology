        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique opportunity ID in Dynamics 365 Sales</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/salesOpportunity_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/SalesOpportunity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Opportunity name as registered in Dynamics 365 Sales pipeline</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/salesOpportunity_stage">
        <rdfs:label>stage</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/SalesOpportunity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Current sales pipeline stage in Dynamics 365 Sales</rdfs:comment>
        <ont:enumValues>Qualify,Develop,Propose,Close,Won,Lost</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/salesOpportunity_estimatedValue">
        <rdfs:label>estimatedValue</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/SalesOpportunity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Estimated deal value in Dynamics 365 Sales</rdfs:comment>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/salesOpportunity_closeProbability">
        <rdfs:label>closeProbability</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/SalesOpportunity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Probability of closing the opportunity (0-100%), used in Dynamics 365 Sales forecasting</rdfs:comment>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/salesOpportunity_estimatedCloseDate">
        <rdfs:label>estimatedCloseDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/SalesOpportunity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Expected close date of the sales opportunity</rdfs:comment>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- SecurityIncident -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/securityIncident_incidentId">
        <rdfs:label>incidentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/SecurityIncident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique incident ID from Microsoft Sentinel or Defender XDR portal</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/securityIncident_severity">
        <rdfs:label>severity</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/SecurityIncident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Incident severity as classified in Microsoft Sentinel</rdfs:comment>
        <ont:enumValues>Informational,Low,Medium,High,Critical</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/securityIncident_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/SecurityIncident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Current investigation status of the incident</rdfs:comment>
        <ont:enumValues>New,Active,Resolved,Closed,FalsePositive</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/securityIncident_detectedAt">
        <rdfs:label>detectedAt</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/SecurityIncident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>Timestamp when the incident was first detected in Microsoft Sentinel</rdfs:comment>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- HardwareAsset -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/hardwareAsset_assetId">
        <rdfs:label>assetId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/HardwareAsset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique hardware asset tag number</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/hardwareAsset_assetType">
        <rdfs:label>assetType</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/HardwareAsset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Type of hardware asset</rdfs:comment>
        <ont:enumValues>Laptop,Desktop,Server,MobilePhone,Tablet,NetworkSwitch,Printer,Monitor</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/hardwareAsset_serialNumber">
        <rdfs:label>serialNumber</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/HardwareAsset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Manufacturer serial number of the hardware asset</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/hardwareAsset_purchaseDate">
        <rdfs:label>purchaseDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/HardwareAsset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date the hardware was purchased</rdfs:comment>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/hardwareAsset_warrantyExpiry">
        <rdfs:label>warrantyExpiry</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/HardwareAsset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Warranty expiry date for the hardware asset</rdfs:comment>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/hardwareAsset_purchaseCost">
        <rdfs:label>purchaseCost</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/HardwareAsset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Original purchase cost of the hardware asset</rdfs:comment>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Invoice -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/invoice_invoiceId">
        <rdfs:label>invoiceId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Invoice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique invoice number in Dynamics 365 Finance</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/invoice_invoiceDate">
        <rdfs:label>invoiceDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Invoice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date the invoice was issued or received</rdfs:comment>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/invoice_dueDate">
        <rdfs:label>dueDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Invoice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Payment due date for the invoice</rdfs:comment>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/invoice_amount">
        <rdfs:label>amount</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Invoice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Total invoice amount</rdfs:comment>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/invoice_paymentStatus">
        <rdfs:label>paymentStatus</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Invoice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Payment status of the invoice in Dynamics 365 Finance</rdfs:comment>
        <ont:enumValues>Pending,PartiallyPaid,Paid,Overdue,Disputed,Cancelled</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ================================================================ -->
    <!-- OBJECT PROPERTIES (Relationships)                                 -->
    <!-- ================================================================ -->

    <!-- Company → BusinessUnit -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/company_has_businessUnit">
        <rdfs:label>hasBusinessUnit</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Company"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/BusinessUnit"/>
        <rdfs:comment>A company is organized into multiple business units</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>company</ont:fromEntityId>
        <ont:toEntityId>businessUnit</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- BusinessUnit → Department -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/businessUnit_contains_department">
        <rdfs:label>containsDepartment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/BusinessUnit"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/Department"/>
        <rdfs:comment>A business unit contains one or more departments</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>businessUnit</ont:fromEntityId>
        <ont:toEntityId>department</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Department → CostCenter -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/department_mapped_to_costCenter">
        <rdfs:label>mappedToCostCenter</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Department"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/CostCenter"/>
        <rdfs:comment>A department is mapped to a cost center in Dynamics 365 Finance for budget tracking</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>department</ont:fromEntityId>
        <ont:toEntityId>costCenter</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Employee → Department -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/employee_belongs_to_department">
        <rdfs:label>belongsToDepartment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Employee"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/Department"/>
        <rdfs:comment>An employee belongs to a department as recorded in Dynamics 365 HR and Entra ID</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>employee</ont:fromEntityId>
        <ont:toEntityId>department</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Employee → Employee (manager) -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/employee_reports_to_employee">
        <rdfs:label>reportsTo</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Employee"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/Employee"/>
        <rdfs:comment>Manager relationship between employees as configured in Entra ID and Dynamics 365 HR org chart</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>employee</ont:fromEntityId>
        <ont:toEntityId>employee</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Employee → Role -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/employee_assigned_role">
        <rdfs:label>assignedRole</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Employee"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/Role"/>
        <rdfs:comment>A role assigned to an employee within the organization</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>employee</ont:fromEntityId>
        <ont:toEntityId>role</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Employee → EntraIDUser -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/employee_has_entraIdUser">
        <rdfs:label>hasEntraIdUser</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Employee"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/EntraIDUser"/>
        <rdfs:comment>Each employee has a corresponding Microsoft Entra ID identity record</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>employee</ont:fromEntityId>
        <ont:toEntityId>entraIDUser</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Employee → OutlookMailbox -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/employee_has_mailbox">
        <rdfs:label>hasMailbox</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Employee"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/OutlookMailbox"/>
        <rdfs:comment>An employee is provisioned an Exchange Online mailbox through Microsoft 365</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>employee</ont:fromEntityId>
        <ont:toEntityId>outlookMailbox</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Employee → OneDriveDrive -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/employee_has_oneDrive">
        <rdfs:label>hasOneDrive</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Employee"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/OneDriveDrive"/>
        <rdfs:comment>An employee is provisioned a OneDrive for Business storage drive in Microsoft 365</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>employee</ont:fromEntityId>
        <ont:toEntityId>oneDriveDrive</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Employee → SoftwareLicense -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/employee_assigned_license">
        <rdfs:label>assignedLicense</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Employee"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/SoftwareLicense"/>
        <rdfs:comment>Microsoft 365 or Dynamics 365 licenses assigned to an employee via the M365 Admin Center</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>employee</ont:fromEntityId>
        <ont:toEntityId>softwareLicense</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Employee → HardwareAsset -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/employee_uses_hardwareAsset">
        <rdfs:label>usesHardwareAsset</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Employee"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/HardwareAsset"/>
        <rdfs:comment>A hardware asset (laptop, phone) assigned to and used by an employee</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>employee</ont:fromEntityId>
        <ont:toEntityId>hardwareAsset</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Employee → HRRecord -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/employee_has_hrRecord">
        <rdfs:label>hasHRRecord</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Employee"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/HRRecord"/>
        <rdfs:comment>An employee has a corresponding HR record in Dynamics 365 Human Resources</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>employee</ont:fromEntityId>
        <ont:toEntityId>hRRecord</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Employee → Team -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/employee_member_of_team">
        <rdfs:label>memberOfTeam</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Employee"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/Team"/>
        <rdfs:comment>An employee is a member of one or more Microsoft Teams groups</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>employee</ont:fromEntityId>
        <ont:toEntityId>team</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Team → TeamsChannel -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/team_has_channel">
        <rdfs:label>hasChannel</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Team"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/TeamsChannel"/>
        <rdfs:comment>A Microsoft Teams group has one or more channels for communication</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>team</ont:fromEntityId>
        <ont:toEntityId>teamsChannel</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Team → SharePointSite -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/team_has_sharePointSite">
        <rdfs:label>hasSharePointSite</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Team"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/SharePointSite"/>
        <rdfs:comment>Each Microsoft Team automatically provisions a linked SharePoint Online team site</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>team</ont:fromEntityId>
        <ont:toEntityId>sharePointSite</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Project → Department -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/project_owned_by_department">
        <rdfs:label>ownedByDepartment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Project"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/Department"/>
        <rdfs:comment>A project is owned and budgeted under a specific department</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>project</ont:fromEntityId>
        <ont:toEntityId>department</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Project → Employee (Project Manager) -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/project_managed_by_employee">
        <rdfs:label>managedBy</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Project"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/Employee"/>
        <rdfs:comment>The employee serving as Project Manager in Azure DevOps or Project Operations</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>project</ont:fromEntityId>
        <ont:toEntityId>employee</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Project → Employee (Members) -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/project_has_member_employee">
        <rdfs:label>hasMember</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Project"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/Employee"/>
        <rdfs:comment>Employees assigned to work on the project as team members in Azure DevOps</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>project</ont:fromEntityId>
        <ont:toEntityId>employee</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Project → Sprint -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/project_has_sprint">
        <rdfs:label>hasSprint</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Project"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/Sprint"/>
        <rdfs:comment>A project is executed through multiple Azure DevOps sprints</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>project</ont:fromEntityId>
        <ont:toEntityId>sprint</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- Sprint → WorkItem -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/enterprise-msft/sprint_contains_workItem">
        <rdfs:label>containsWorkItem</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Sprint"/>
        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/WorkItem"/>
        <rdfs:comment>A sprint contains work items (tasks, stories, bugs) committed for delivery</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>sprint</ont:fromEntityId>
        <ont:toEntityId>workItem</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- WorkItem → Employee (Assigned To) -->
