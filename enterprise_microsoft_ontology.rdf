<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/enterprise-msft/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/enterprise-msft/">

    <owl:Ontology rdf:about="http://example.org/ontology/enterprise-msft/">
        <rdfs:label>Enterprise Microsoft Operations Ontology</rdfs:label>
        <rdfs:comment>A comprehensive ontology describing the full operations of a large enterprise company built on the Microsoft technology stack. Covers organizational structure, workforce, projects, assets, IT infrastructure, procurement, licensing, compliance, financials, and integrations across Microsoft 365, Azure, Dynamics 365, Power Platform, and more.</rdfs:comment>
    </owl:Ontology>

    <!-- ======================================================= -->
    <!-- ENTITY TYPES (Classes)                                   -->
    <!-- SECTION 1 – Organization Structure                       -->
    <!-- ======================================================= -->

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/Company">
        <rdfs:label>Company</rdfs:label>
        <rdfs:comment>The top-level legal entity operating the enterprise</rdfs:comment>
        <ont:icon>🏢</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/BusinessUnit">
        <rdfs:label>BusinessUnit</rdfs:label>
        <rdfs:comment>A major operational division of the company (e.g., Finance, Engineering, Sales, Operations)</rdfs:comment>
        <ont:icon>🏛️</ont:icon>
        <ont:color>#106EBE</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/Department">
        <rdfs:label>Department</rdfs:label>
        <rdfs:comment>A functional unit within a Business Unit (e.g., Payroll, DevOps, Enterprise Sales)</rdfs:comment>
        <ont:icon>📂</ont:icon>
        <ont:color>#2B88D8</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/CostCenter">
        <rdfs:label>CostCenter</rdfs:label>
        <rdfs:comment>A financial tracking unit used in Dynamics 365 Finance for budget and expenditure allocation</rdfs:comment>
        <ont:icon>💰</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/Office">
        <rdfs:label>Office</rdfs:label>
        <rdfs:comment>A physical or virtual office location of the enterprise</rdfs:comment>
        <ont:icon>📍</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <!-- SECTION 2 – People -->

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/Employee">
        <rdfs:label>Employee</rdfs:label>
        <rdfs:comment>A full-time or part-time staff member with an Active Directory / Entra ID account</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/Contractor">
        <rdfs:label>Contractor</rdfs:label>
        <rdfs:comment>An external or temporary worker engaged via a vendor or staffing agency</rdfs:comment>
        <ont:icon>🧑‍💼</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/Role">
        <rdfs:label>Role</rdfs:label>
        <rdfs:comment>A job role or position such as Software Engineer, Project Manager, or CFO</rdfs:comment>
        <ont:icon>🎭</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/Team">
        <rdfs:label>Team</rdfs:label>
        <rdfs:comment>A Microsoft Teams group or cross-functional team within the enterprise</rdfs:comment>
        <ont:icon>👥</ont:icon>
        <ont:color>#6264A7</ont:color>
    </owl:Class>

    <!-- SECTION 3 – Projects & Work -->

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/Project">
        <rdfs:label>Project</rdfs:label>
        <rdfs:comment>A time-bound initiative tracked in Microsoft Project or Azure DevOps</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/Sprint">
        <rdfs:label>Sprint</rdfs:label>
        <rdfs:comment>An Agile sprint or iteration tracked in Azure DevOps Boards</rdfs:comment>
        <ont:icon>🏃</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/WorkItem">
        <rdfs:label>WorkItem</rdfs:label>
        <rdfs:comment>An Azure DevOps work item: Epic, Feature, User Story, Task, or Bug</rdfs:comment>
        <ont:icon>✅</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/Milestone">
        <rdfs:label>Milestone</rdfs:label>
        <rdfs:comment>A key project deliverable or deadline checkpoint in Microsoft Project</rdfs:comment>
        <ont:icon>🎯</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <!-- SECTION 4 – IT Infrastructure (Azure) -->

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/AzureSubscription">
        <rdfs:label>AzureSubscription</rdfs:label>
        <rdfs:comment>A Microsoft Azure billing subscription used by the enterprise</rdfs:comment>
        <ont:icon>☁️</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/AzureResourceGroup">
        <rdfs:label>AzureResourceGroup</rdfs:label>
        <rdfs:comment>A logical container for Azure resources within a subscription</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#106EBE</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/AzureResource">
        <rdfs:label>AzureResource</rdfs:label>
        <rdfs:comment>An individual Azure resource such as a VM, Storage Account, SQL Database, Key Vault, or Function App</rdfs:comment>
        <ont:icon>⚙️</ont:icon>
        <ont:color>#2B88D8</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/AzurePolicy">
        <rdfs:label>AzurePolicy</rdfs:label>
        <rdfs:comment>A governance policy applied to Azure resources to enforce compliance rules</rdfs:comment>
        <ont:icon>🔒</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/EntraIDUser">
        <rdfs:label>EntraIDUser</rdfs:label>
        <rdfs:comment>A Microsoft Entra ID (formerly Azure Active Directory) user account</rdfs:comment>
        <ont:icon>🆔</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/EntraIDGroup">
        <rdfs:label>EntraIDGroup</rdfs:label>
        <rdfs:comment>A security or Microsoft 365 group in Microsoft Entra ID</rdfs:comment>
        <ont:icon>🛡️</ont:icon>
        <ont:color>#744DA9</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/ConditionalAccessPolicy">
        <rdfs:label>ConditionalAccessPolicy</rdfs:label>
        <rdfs:comment>An Entra ID Conditional Access Policy controlling authentication requirements</rdfs:comment>
        <ont:icon>🔐</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <!-- SECTION 5 – Microsoft 365 Collaboration -->

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/M365Tenant">
        <rdfs:label>M365Tenant</rdfs:label>
        <rdfs:comment>The enterprise's Microsoft 365 tenant — the root of all M365 services</rdfs:comment>
        <ont:icon>🌐</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/TeamsChannel">
        <rdfs:label>TeamsChannel</rdfs:label>
        <rdfs:comment>A Microsoft Teams channel used for departmental or project communication</rdfs:comment>
        <ont:icon>💬</ont:icon>
        <ont:color>#6264A7</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/SharePointSite">
        <rdfs:label>SharePointSite</rdfs:label>
        <rdfs:comment>A SharePoint Online site used for document management, intranet pages, or team collaboration</rdfs:comment>
        <ont:icon>📄</ont:icon>
        <ont:color>#038387</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/OneDriveDrive">
        <rdfs:label>OneDriveDrive</rdfs:label>
        <rdfs:comment>An employee's OneDrive for Business storage drive</rdfs:comment>
        <ont:icon>🗂️</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/OutlookMailbox">
        <rdfs:label>OutlookMailbox</rdfs:label>
        <rdfs:comment>An Exchange Online mailbox associated with an employee or shared account</rdfs:comment>
        <ont:icon>📧</ont:icon>
        <ont:color>#0072C6</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/CalendarEvent">
        <rdfs:label>CalendarEvent</rdfs:label>
        <rdfs:comment>A meeting or event scheduled via Outlook or Teams Calendar</rdfs:comment>
        <ont:icon>📅</ont:icon>
        <ont:color>#106EBE</ont:color>
    </owl:Class>

    <!-- SECTION 6 – Power Platform -->

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/PowerApp">
        <rdfs:label>PowerApp</rdfs:label>
        <rdfs:comment>A canvas or model-driven app built with Microsoft Power Apps</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#742774</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/PowerAutomateFlow">
        <rdfs:label>PowerAutomateFlow</rdfs:label>
        <rdfs:comment>An automated workflow created in Microsoft Power Automate (formerly Flow)</rdfs:comment>
        <ont:icon>🔄</ont:icon>
        <ont:color>#0066FF</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/PowerBIReport">
        <rdfs:label>PowerBIReport</rdfs:label>
        <rdfs:comment>A Power BI report or dashboard used for enterprise analytics and KPI reporting</rdfs:comment>
        <ont:icon>📊</ont:icon>
        <ont:color>#F2C811</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/PowerBIDataset">
        <rdfs:label>PowerBIDataset</rdfs:label>
        <rdfs:comment>A semantic model (dataset) powering Power BI reports</rdfs:comment>
        <ont:icon>🗄️</ont:icon>
        <ont:color>#C8A600</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/DataverseTable">
        <rdfs:label>DataverseTable</rdfs:label>
        <rdfs:comment>A Microsoft Dataverse table storing business data used across Power Platform and Dynamics 365</rdfs:comment>
        <ont:icon>🗃️</ont:icon>
        <ont:color>#038387</ont:color>
    </owl:Class>

    <!-- SECTION 7 – Dynamics 365 & Business Applications -->

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/D365Environment">
        <rdfs:label>D365Environment</rdfs:label>
        <rdfs:comment>A Dynamics 365 environment (Production, Sandbox, Development)</rdfs:comment>
        <ont:icon>🌍</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/CRMAccount">
        <rdfs:label>CRMAccount</rdfs:label>
        <rdfs:comment>A customer or partner account record in Dynamics 365 Sales or Customer Service</rdfs:comment>
        <ont:icon>🏪</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/CRMContact">
        <rdfs:label>CRMContact</rdfs:label>
        <rdfs:comment>A contact record linked to a CRM account in Dynamics 365</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#2B88D8</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/SalesOpportunity">
        <rdfs:label>SalesOpportunity</rdfs:label>
        <rdfs:comment>A sales pipeline opportunity tracked in Dynamics 365 Sales</rdfs:comment>
        <ont:icon>💼</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/SalesQuote">
        <rdfs:label>SalesQuote</rdfs:label>
        <rdfs:comment>A formal price quote issued to a prospect or customer via Dynamics 365 Sales</rdfs:comment>
        <ont:icon>🧾</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/SalesOrder">
        <rdfs:label>SalesOrder</rdfs:label>
        <rdfs:comment>A confirmed sales order in Dynamics 365 Sales integrated with Finance and Operations</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/ServiceCase">
        <rdfs:label>ServiceCase</rdfs:label>
        <rdfs:comment>A customer support case managed in Dynamics 365 Customer Service</rdfs:comment>
        <ont:icon>🎧</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/FinanceJournal">
        <rdfs:label>FinanceJournal</rdfs:label>
        <rdfs:comment>A general ledger or sub-ledger journal entry in Dynamics 365 Finance</rdfs:comment>
        <ont:icon>📒</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/PurchaseOrder">
        <rdfs:label>PurchaseOrder</rdfs:label>
        <rdfs:comment>A procurement purchase order raised in Dynamics 365 Supply Chain Management or Finance</rdfs:comment>
        <ont:icon>🛒</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/Vendor">
        <rdfs:label>Vendor</rdfs:label>
        <rdfs:comment>An external vendor or supplier registered in Dynamics 365 Finance or Procurement</rdfs:comment>
        <ont:icon>🚚</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/Invoice">
        <rdfs:label>Invoice</rdfs:label>
        <rdfs:comment>A vendor or customer invoice processed through Dynamics 365 Finance accounts payable or receivable</rdfs:comment>
        <ont:icon>📑</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <!-- SECTION 8 – Asset & License Management -->

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/HardwareAsset">
        <rdfs:label>HardwareAsset</rdfs:label>
        <rdfs:comment>A physical hardware asset (laptop, desktop, server, phone) tracked in the enterprise CMDB or Intune</rdfs:comment>
        <ont:icon>💻</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/SoftwareLicense">
        <rdfs:label>SoftwareLicense</rdfs:label>
        <rdfs:comment>A Microsoft or third-party software license assigned to an employee or device, tracked via Microsoft 365 Admin Center or VLSC</rdfs:comment>
        <ont:icon>🔑</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/IntuneDevice">
        <rdfs:label>IntuneDevice</rdfs:label>
        <rdfs:comment>A device enrolled and managed by Microsoft Intune (MDM/MAM)</rdfs:comment>
        <ont:icon>📱</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/CompliancePolicy">
        <rdfs:label>CompliancePolicy</rdfs:label>
        <rdfs:comment>A Microsoft Purview or Intune compliance policy applied to devices or data</rdfs:comment>
        <ont:icon>📜</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <!-- SECTION 9 – Security & Governance -->

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/SecurityIncident">
        <rdfs:label>SecurityIncident</rdfs:label>
        <rdfs:comment>A security incident logged in Microsoft Sentinel or Defender XDR</rdfs:comment>
        <ont:icon>🚨</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/DefenderAlert">
        <rdfs:label>DefenderAlert</rdfs:label>
        <rdfs:comment>An alert raised by Microsoft Defender for Endpoint, Identity, Cloud, or Office 365</rdfs:comment>
        <ont:icon>⚠️</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/DataClassification">
        <rdfs:label>DataClassification</rdfs:label>
        <rdfs:comment>A Microsoft Purview sensitivity label or information protection classification applied to data</rdfs:comment>
        <ont:icon>🏷️</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/AuditLog">
        <rdfs:label>AuditLog</rdfs:label>
        <rdfs:comment>A unified audit log entry from Microsoft Purview Audit recording user or admin activities</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <!-- SECTION 10 – HR & Training -->

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/HRRecord">
        <rdfs:label>HRRecord</rdfs:label>
        <rdfs:comment>An employee HR record in Dynamics 365 Human Resources covering employment details, payroll, and benefits</rdfs:comment>
        <ont:icon>📁</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/TrainingCourse">
        <rdfs:label>TrainingCourse</rdfs:label>
        <rdfs:comment>A learning course published via Microsoft Viva Learning or an integrated LMS</rdfs:comment>
        <ont:icon>🎓</ont:icon>
        <ont:color>#744DA9</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/enterprise-msft/PerformanceReview">
        <rdfs:label>PerformanceReview</rdfs:label>
        <rdfs:comment>An employee performance review cycle tracked in Dynamics 365 HR or Viva Goals</rdfs:comment>
        <ont:icon>⭐</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <!-- ================================================================ -->
    <!-- DATA PROPERTIES                                                   -->
    <!-- ================================================================ -->

    <!-- Company -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/company_companyId">
        <rdfs:label>companyId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Company"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique company identifier (e.g., used in Dynamics 365 legal entity code)</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/company_legalName">
        <rdfs:label>legalName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Company"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Official registered legal name of the company</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/company_tenantId">
        <rdfs:label>tenantId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Company"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Microsoft Entra ID tenant GUID associated with the company's Microsoft 365 tenant</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/company_domainName">
        <rdfs:label>domainName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Company"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Primary email domain (e.g., contoso.com) registered with Microsoft 365</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/company_industry">
        <rdfs:label>industry</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Company"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Industry sector of the company (e.g., Financial Services, Manufacturing, Retail)</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/company_headquartersCity">
        <rdfs:label>headquartersCity</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Company"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>City where the company headquarters is located</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/company_employeeCount">
        <rdfs:label>employeeCount</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Company"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Total number of employees across all offices</rdfs:comment>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/enterprise-msft/company_annualRevenue">
        <rdfs:label>annualRevenue</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/enterprise-msft/Company"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Most recent annual revenue in USD</rdfs:comment>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- BusinessUnit -->
