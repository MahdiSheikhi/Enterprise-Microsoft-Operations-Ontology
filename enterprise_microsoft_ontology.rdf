        <rdfs:range rdf:resource="http://example.org/ontology/enterprise-msft/Invoice"/>
        <rdfs:comment>A vendor invoice is three-way matched against the purchase order in Dynamics 365 Finance AP</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
